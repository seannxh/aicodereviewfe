# Copy this file to `.env.local` and adjust for your environment.
# Only variables prefixed with VITE_ are exposed to the client bundle.

# Base URL of the backend API. Defaults to the local Spring backend.
VITE_API_BASE_URL=http://localhost:8080

# Slug of the GitHub App used for the installation flow
# (https://github.com/apps/<slug>).
VITE_GITHUB_APP_SLUG=sean-ai-code-reviewer
